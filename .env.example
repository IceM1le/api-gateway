APP_NAME=API Gateway

APP_VERSION=1.0.0

DEBUG=True

HOST=0.0.0.0
PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=redis
REDIS_PORT=6379

API_KEY=my-secret-key

CACHE_TTL=300

RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=30